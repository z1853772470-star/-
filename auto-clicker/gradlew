#!/bin/sh

# Gradle wrapper start script
# This is a placeholder. In production, this should contain the actual Gradle wrapper binary.

if [ -z "$JAVA_HOME" ]; then
    echo "JAVA_HOME is not set. Please set JAVA_HOME to your JDK installation directory."
    exit 1
fi

if [ ! -f "$JAVA_HOME/bin/java" ]; then
    echo "Cannot find java executable. Please check your JAVA_HOME."
    exit 1
fi

# Use the gradle wrapper jar
SCRIPT_DIR="$( cd "$( dirname "$0" )" && pwd )"
if [ -f "$SCRIPT_DIR/gradle/wrapper/gradle-wrapper.jar" ]; then
    exec "$JAVA_HOME/bin/java" -jar "$SCRIPT_DIR/gradle/wrapper/gradle-wrapper.jar" "$@"
else
    echo "Gradle wrapper jar not found. Please run 'gradle wrapper' first or use Android Studio."
    exit 1
fi
